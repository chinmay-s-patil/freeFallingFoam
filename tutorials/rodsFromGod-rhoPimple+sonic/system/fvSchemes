FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    // backward is 2nd-order in time — important for LES
    default         backward;
}

gradSchemes
{
    default             Gauss linear;
    grad(U)             cellLimited Gauss linear 1;
}

divSchemes
{
    default             Gauss linear;

    // Momentum: LUST (75% central + 25% linearUpwind) — standard LES compromise
    div(phi,U)          Gauss LUST grad(U);

    // Compressible energy transport (rhoPimpleFoam)
    div(phi,h)          Gauss linearUpwind grad(h);
    div(phi,e)          Gauss linearUpwind grad(e);
    div(phi,K)          Gauss linear;

    // Density flux divergence (used in rhoEqn)
    div(phiv,p)         Gauss linear;

    // Compressible SGS stress divergence
    div((muEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default             Gauss linear corrected;
}

interpolationSchemes
{
    default             linear;
}

snGradSchemes
{
    default             corrected;
}

